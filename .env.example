DATABASE_URL=postgresql://postgres:postgres@localhost:5432/picxel
PORT=5000

# Split deploy: frontend origin (Stripe success/cancel redirects). No trailing slash required.
# Example: https://your-app.vercel.app
APP_BASE_URL=http://localhost:5000

# Extra browser origins allowed for CORS (comma-separated). Use for alternate domains or Vercel preview URLs.
# Example: https://pickel-puzzle.vercel.app,https://picxel-puzzle.vercel.app
# CORS_ALLOWED_ORIGINS=

# Split deploy: public API URL baked into the Vite client at build time (Railway).
# Set this in Vercel project → Settings → Environment Variables for Production (and Preview).
# Example: https://your-api.up.railway.app
# VITE_API_URL=

# --- Vercel (client/) ---
# Set Vercel project Root Directory to "client" if you deploy the SPA from this repo.
#
# Purchase success and /api/* from the browser: either
# (A) Set VITE_API_URL at Vercel build time so the client calls Railway directly (CORS must allow APP_BASE_URL), or
# (B) Leave VITE_API_URL unset and rely on client/vercel.json: /api/* is proxied to Railway (same-origin, no CORS).
#     Update the "destination" host in client/vercel.json if your Railway URL changes, or run:
#     RAILWAY_PUBLIC_URL=https://your-api.up.railway.app node scripts/write-vercel-api-rewrite.mjs

# Optional override for listen address (default: 127.0.0.1 in dev, 0.0.0.0 in production)
# HOST=0.0.0.0

# Stripe (Railway / server). Webhook URL in Dashboard: https://<railway-host>/api/webhooks/stripe
# Event: checkout.session.completed
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID=

# Postgres TLS (remote hosts use SSL by default; local hosts do not unless DATABASE_SSL=true)
# DATABASE_SSL=false
# DATABASE_SSL=true
# sslmode=require (typical for Neon/Railway) matches libpq: encrypted, identity not verified by default.
# Use sslmode=verify-full (or verify-ca) + system CAs, or DATABASE_SSL_CA_FILE, for strict verification.
# Force verify for any sslmode: DATABASE_SSL_REJECT_UNAUTHORIZED=true
# Force skip verify: DATABASE_SSL_REJECT_UNAUTHORIZED=false
# Trust your org CA globally: export NODE_EXTRA_CA_CERTS=/absolute/path/to/ca.pem
# Pin a CA bundle for this connection only (e.g. AWS RDS combined CA PEM):
# DATABASE_SSL_CA_FILE=/absolute/path/to/rds-combined-ca-bundle.pem

# Licensing
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_VALIDATE_URL=https://api.lemonsqueezy.com/v1/licenses/validate
LICENSE_SIGNING_SECRET=change-me-in-production
LICENSE_OFFLINE_DAYS=7
LICENSE_MAX_DEVICES=2

# Stripe API TLS: set to false only behind a corporate proxy / self-signed MITM (dev). Default verifies certificates.
# STRIPE_TLS_REJECT_UNAUTHORIZED=false
# Trust your org CA for all Node TLS (Postgres, Stripe, etc.): export before npm run dev / start:desktop (not loaded from .env):
# NODE_EXTRA_CA_CERTS=/absolute/path/to/ca.pem
