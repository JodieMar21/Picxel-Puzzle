DATABASE_URL=postgresql://postgres:postgres@localhost:5432/picxel
PORT=5000

# Licensing
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_VALIDATE_URL=https://api.lemonsqueezy.com/v1/licenses/validate
LICENSE_SIGNING_SECRET=change-me-in-production
LICENSE_OFFLINE_DAYS=7
LICENSE_MAX_DEVICES=2

# Stripe API TLS: set to false only behind a corporate proxy / self-signed MITM (dev). Default verifies certificates.
# STRIPE_TLS_REJECT_UNAUTHORIZED=false
# Prefer trusting your org CA (not loaded from .env — export in the shell before npm run dev / start:desktop):
# NODE_EXTRA_CA_CERTS=/absolute/path/to/ca.pem
